{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "the shop",
  "version": "0.5.0",
  "identifier": "gg.the-shop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "the shop",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/hsd-tool/*"
    ],
    "category": "Utility",
    "shortDescription": "Slippi skin manager",
    "longDescription": "Browse, install, and play with custom Melee skins on Slippi."
  },
  "plugins": {}
}
